{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch --show-current)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh auth status)",
      "Bash(yarn format:check)",
      "Bash(yarn test:*)"
    ]
  }
}
